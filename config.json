{
  "system": {
    "mode": "online",
    "loop_interval": 0.1,
    "max_errors": 10,
    "error_reset_time": 60,
    "log_level": "INFO",
    "log_file": "smart_hospital.log"
  },
  "network": {
    "network_mode": "mqtt",
    "platform": "onenet",
    "mqtt_broker": "mqtt.heclouds.com",
    "mqtt_port": 1883,
    "product_id": "你的产品ID",
    "device_name": "你的设备名称",
    "token": "你的Token（使用 onenet_token.py 生成）",
    "mqtt_topic": "$sys/{pid}/{device-name}/thing/property/set",
    "result_topic": "$sys/{pid}/{device-name}/thing/property/post",
    "heartbeat_interval": 30,
    "reconnect_interval": 5
  },
  "ai": {
    "model_type": "mediapipe_pose",
    "confidence_threshold": 0.5,
    "min_detection_confidence": 0.5,
    "min_tracking_confidence": 0.5,
    "input_resolution": [640, 480],
    "max_num_poses": 5,
    "frame_skip": 1,
    "max_memory_mb": 1500
  },
  "post_processing": {
    "confidence_threshold": 0.5,
    "angle_thresholds": {
      "squat": {
        "knee": [90, 140],
        "hip": [80, 120]
      },
      "pushup": {
        "elbow": [60, 120],
        "shoulder": [80, 160]
      },
      "jump": {
        "knee": [150, 180],
        "ankle": [80, 110]
      }
    }
  },
  "visualizer": {
    "draw_frame_skip": 3,
    "line_color": [0, 255, 0],
    "line_thickness": 2,
    "text_color": [0, 255, 255],
    "text_size": 24
  },
  "voice_tts": {
    "enabled": false,
    "device_type": "syn6288",
    "serial_port": "/dev/ttyUSB0",
    "baudrate": 9600,
    "min_interval": 3.0
  }
}
